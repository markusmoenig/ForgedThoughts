let camera = Camera {
  origin: vec3(0.2, 1.8, 8.2),
  target: vec3(0.2, 0.9, 0.0),
  fov_y: 30.0
};

let key = SphereLight {
  position: vec3(2.5, 3.8, 3.5),
  radius: 0.7,
  color: #fff0d8,
  intensity: 120.0,
  samples: 4
};

environment Sky {
  fn color(dir) {
    let t = clamp(dir.y * 0.5 + 0.5, 0.0, 1.0);
    return mix(#e6f0ff, #6ea2ff, pow(t, 0.65));
  }
};

let wall_mat = Lambert {
  color: #f2efe8
};

let statue_mat = Lambert {
  color: #c9ccd1
};

let render = RenderSettings {
  width: 220,
  height: 220,
  max_steps: 560,
  max_dist: 80.0,
  epsilon: 0.0002,
  step_scale: 0.7,
  accel: Bvh{}
};

let room = Room {
  width: 8.0,
  height: 4.0,
  depth: 8.0,
  wall_thickness: 0.18,
  floor_material: wall_mat,
  wall_material: wall_mat,
  show_back_wall: 1.0,
  show_right_wall: 1.0,
  show_left_wall: 0.0,
  show_front_wall: 0.0,
  show_ceiling: 0.0
};

var statue = Box {
  size: vec3(0.55, 1.5, 0.42),
  material: statue_mat
}
  .attach(room, Top)
  .offset_x(-1.8)
  .offset_z(0.6);
statue.domain = fn(p) {
  return rotate_y(p, p.y * 18.0);
};
statue.distance_post = fn(d, p) {
  let bands = sin((p.y + 0.75) * 115.0) * 0.0045;
  return abs(d + bands) - 0.028;
};

let scene = room + statue;
