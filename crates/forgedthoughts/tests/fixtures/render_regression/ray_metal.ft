let camera = Camera {
  origin: vec3(0.0, 1.5, 6.2),
  target: vec3(0.0, 0.5, 0.0),
  fov_y: 35.0
};

let key = PointLight {
  position: vec3(3.8, 4.8, 4.6),
  color: #fff2d8,
  intensity: 125.0
};

let fill = PointLight {
  position: vec3(-3.4, 2.7, 3.0),
  color: #d6e4ff,
  intensity: 24.0
};

environment Sky {
  let zenith = #5a95ff;
  let horizon = #dcecff;
  let nadir = #f0f4fa;

  fn color(dir) {
    let t = clamp(dir.y * 0.5 + 0.5, 0.0, 1.0);
    let sky = mix(horizon, zenith, pow(t, 0.8));
    let down = clamp(-dir.y * 1.6, 0.0, 1.0);
    return mix(sky, nadir, down);
  }
};

let floor_mat = Lambert {
  color: #d2d8e1
};

let metal_mat = Metal {
  color: #d4af37,
  roughness: 0.28
};

var floor = Box {
  size: vec3(12.0, 0.5, 12.0),
  material: floor_mat
};
floor.pos.y = -1.15;

var sphere = Sphere {
  radius: 0.95,
  material: metal_mat
};
sphere.pos.y = 0.3;

let scene = floor + sphere;
